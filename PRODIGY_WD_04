<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jayashri R — Front-End Developer</title>
<style>
  :root{
    --ink:#12122b;
    --cream:#fff9f0;
    --pink:#ff3d7f;
    --violet:#6c4cf1;
    --teal:#00d9c0;
    --yellow:#ffc93d;
    --paper:#ffffff;
    --shadow: 6px 6px 0 var(--ink);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--cream);
    color:var(--ink);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height:1.6;
    overflow-x:hidden;
  }
  h1,h2,h3,h4{
    font-family: Georgia, "Palatino Linotype", "Book Antiqua", serif;
    font-weight:700;
    line-height:1.1;
  }
  .label{
    font-family:"Courier New", Courier, monospace;
    text-transform:uppercase;
    letter-spacing:0.18em;
    font-size:0.75rem;
    font-weight:700;
  }
  a{color:inherit; text-decoration:none;}
  ::selection{background:var(--pink); color:var(--cream);}

  /* ---------- background blobs ---------- */
  .blob{
    position:fixed;
    border-radius:50%;
    filter:blur(70px);
    opacity:0.35;
    z-index:0;
    pointer-events:none;
    animation: drift 18s ease-in-out infinite;
  }
  #blob1{width:420px; height:420px; background:var(--pink); top:-120px; left:-100px;}
  #blob2{width:380px; height:380px; background:var(--teal); top:40%; right:-140px; animation-delay:-6s;}
  #blob3{width:340px; height:340px; background:var(--yellow); bottom:-100px; left:20%; animation-delay:-11s;}
  @keyframes drift{
    0%,100%{ transform:translate(0,0) scale(1); }
    33%{ transform:translate(30px,-40px) scale(1.08); }
    66%{ transform:translate(-25px,25px) scale(0.95); }
  }
  @media (prefers-reduced-motion: reduce){
    .blob{animation:none;}
    *{animation-duration:0.001ms !important; transition-duration:0.001ms !important;}
  }

  /* ---------- nav ---------- */
  nav{
    position:sticky; top:0; z-index:50;
    display:flex; align-items:center; justify-content:space-between;
    padding:1.1rem 6vw;
    background:rgba(255,249,240,0.85);
    backdrop-filter:blur(8px);
    border-bottom:3px solid var(--ink);
  }
  .logo{font-family:Georgia,serif; font-weight:700; font-size:1.4rem; font-style:italic;}
  .logo span{color:var(--pink);}
  .nav-links{display:flex; gap:2rem;}
  .nav-links a{
    font-family:"Courier New",monospace; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.08em;
    position:relative; padding-bottom:4px;
  }
  .nav-links a::after{
    content:""; position:absolute; left:0; bottom:0; height:3px; width:0;
    background:var(--violet); transition:width .25s ease;
  }
  .nav-links a:hover::after{width:100%;}
  .burger{display:none; flex-direction:column; gap:5px; cursor:pointer; background:none; border:none;}
  .burger span{width:26px; height:3px; background:var(--ink); border-radius:2px;}

  section{position:relative; z-index:1; padding:6rem 6vw;}

  /* ---------- hero ---------- */
  .hero{
    min-height:88vh;
    display:grid; grid-template-columns:1.15fr 0.85fr; align-items:center; gap:3rem;
    padding-top:3rem;
  }
  .eyebrow{
    display:inline-block; background:var(--yellow); border:3px solid var(--ink); border-radius:30px;
    padding:0.35rem 1rem; margin-bottom:1.3rem; transform:rotate(-2deg);
  }
  .hero h1{
    font-size:clamp(2.6rem, 5.2vw, 4.4rem);
    font-style:italic;
  }
  .hero h1 .hl{
    background:linear-gradient(180deg, transparent 62%, var(--teal) 62%);
  }
  .hero p.sub{
    margin-top:1.4rem; font-size:1.15rem; max-width:46ch; color:#3a3a55;
  }
  .chip-row{display:flex; flex-wrap:wrap; gap:0.7rem; margin-top:1.8rem;}
  .chip{
    font-family:"Courier New",monospace; font-size:0.8rem; font-weight:700;
    padding:0.4rem 0.9rem; border:2.5px solid var(--ink); border-radius:20px; background:var(--paper);
    transition:transform .2s ease, background .2s ease;
  }
  .chip:hover{transform:translateY(-3px) rotate(-2deg); background:var(--pink); color:#fff;}
  .cta-row{display:flex; gap:1rem; margin-top:2.2rem; flex-wrap:wrap;}
  .btn{
    font-family:"Courier New",monospace; font-weight:700; text-transform:uppercase; letter-spacing:0.05em;
    padding:0.85rem 1.6rem; border:3px solid var(--ink); border-radius:10px; font-size:0.85rem;
    box-shadow:var(--shadow); transition:transform .15s ease, box-shadow .15s ease; cursor:pointer;
    background:var(--paper);
  }
  .btn.primary{background:var(--violet); color:#fff;}
  .btn:hover{transform:translate(-3px,-3px); box-shadow:9px 9px 0 var(--ink);}
  .btn:active{transform:translate(0,0); box-shadow:2px 2px 0 var(--ink);}

  .avatar-wrap{
    position:relative; display:flex; align-items:center; justify-content:center;
  }
  .avatar{
    width:min(340px, 80%); aspect-ratio:1/1; border-radius:50%;
    background:linear-gradient(135deg, var(--violet), var(--pink) 60%, var(--yellow));
    border:5px solid var(--ink); box-shadow:var(--shadow);
    display:flex; align-items:center; justify-content:center;
    font-family:Georgia,serif; font-weight:700; font-size:5rem; color:#fff;
    animation: float 5s ease-in-out infinite;
  }
  @keyframes float{ 0%,100%{transform:translateY(0);} 50%{transform:translateY(-14px);} }
  .badge-orbit{
    position:absolute; background:var(--paper); border:3px solid var(--ink); border-radius:14px;
    padding:0.5rem 0.8rem; font-family:"Courier New",monospace; font-weight:700; font-size:0.8rem;
    box-shadow:4px 4px 0 var(--ink);
  }
  .b1{top:6%; left:-4%; transform:rotate(-8deg);}
  .b2{bottom:10%; right:-6%; transform:rotate(6deg);}
  .b3{top:52%; left:-12%; transform:rotate(4deg); background:var(--teal);}

  /* ---------- section headers ---------- */
  .section-head{margin-bottom:2.8rem;}
  .section-head .label{color:var(--violet);}
  .section-head h2{font-size:clamp(2rem,3.6vw,2.8rem); font-style:italic; margin-top:0.4rem;}

  /* ---------- skills ---------- */
  .skills-grid{
    display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:1.4rem;
  }
  .skill-card{
    background:var(--paper); border:3px solid var(--ink); border-radius:16px; padding:1.4rem;
    box-shadow:var(--shadow); cursor:pointer; transition:transform .2s ease, box-shadow .2s ease;
  }
  .skill-card:hover{transform:translate(-4px,-4px); box-shadow:10px 10px 0 var(--ink);}
  .skill-card h4{font-family:"Courier New",monospace; font-size:1rem; text-transform:uppercase; letter-spacing:0.05em;}
  .bar-track{
    height:12px; border:2px solid var(--ink); border-radius:8px; margin-top:0.9rem; overflow:hidden; background:#fff;
  }
  .bar-fill{
    height:100%; width:0; border-radius:8px;
    transition:width 1.1s cubic-bezier(.2,.8,.2,1);
  }
  .skill-card small{display:block; margin-top:0.5rem; color:#555; font-size:0.78rem;}

  /* ---------- projects (sticker cards) ---------- */
  .sticker-grid{
    display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2.4rem;
  }
  .sticker{
    background:var(--paper); border:3px solid var(--ink); border-radius:18px; padding:1.6rem;
    box-shadow:var(--shadow); cursor:pointer; transition:transform .25s ease, box-shadow .25s ease;
    position:relative;
  }
  .sticker:nth-child(1){transform:rotate(-2deg);}
  .sticker:nth-child(2){transform:rotate(1.5deg);}
  .sticker:nth-child(3){transform:rotate(-1deg);}
  .sticker:hover{transform:rotate(0deg) translateY(-6px); box-shadow:12px 12px 0 var(--ink);}
  .sticker .tag{
    display:inline-block; font-family:"Courier New",monospace; font-size:0.7rem; font-weight:700;
    padding:0.2rem 0.6rem; border-radius:12px; border:2px solid var(--ink); margin-bottom:0.8rem;
  }
  .sticker h3{font-size:1.4rem; font-style:italic;}
  .sticker p.desc{margin-top:0.6rem; color:#3a3a55; font-size:0.95rem;}
  .sticker .more-hint{
    margin-top:1rem; font-family:"Courier New",monospace; font-size:0.78rem; font-weight:700; color:var(--violet);
  }
  .sticker .details{
    max-height:0; overflow:hidden; transition:max-height .45s ease, margin-top .45s ease; margin-top:0;
  }
  .sticker.expanded .details{ max-height:340px; margin-top:1rem; }
  .sticker.expanded .more-hint{display:none;}
  .details ul{padding-left:1.1rem;}
  .details li{margin-bottom:0.35rem; font-size:0.92rem;}
  .stack-row{display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.8rem;}
  .stack-pill{
    font-family:"Courier New",monospace; font-size:0.7rem; font-weight:700; padding:0.25rem 0.6rem;
    border:2px solid var(--ink); border-radius:10px; background:var(--yellow);
  }

  /* ---------- about / accordion ---------- */
  .about-grid{display:grid; grid-template-columns:1fr 1.3fr; gap:3rem;}
  .about-grid p{color:#3a3a55; margin-bottom:1rem;}
  .accordion-item{
    border:3px solid var(--ink); border-radius:14px; margin-bottom:1rem; overflow:hidden;
    background:var(--paper); box-shadow:5px 5px 0 var(--ink);
  }
  .accordion-head{
    display:flex; align-items:center; justify-content:space-between; padding:1rem 1.3rem; cursor:pointer;
  }
  .accordion-head .label{color:var(--pink);}
  .accordion-head h4{font-size:1.1rem; font-style:italic; margin-top:0.15rem;}
  .accordion-icon{
    width:28px; height:28px; border:2.5px solid var(--ink); border-radius:50%;
    display:flex; align-items:center; justify-content:center; font-weight:900; flex-shrink:0;
    transition:transform .3s ease;
  }
  .accordion-item.open .accordion-icon{transform:rotate(45deg); background:var(--teal);}
  .accordion-body{
    max-height:0; overflow:hidden; transition:max-height .4s ease;
    padding:0 1.3rem;
  }
  .accordion-item.open .accordion-body{ max-height:260px; padding:0 1.3rem 1.2rem; }
  .accordion-body p{font-size:0.94rem; color:#3a3a55;}

  /* ---------- contact ---------- */
  .contact-box{
    background:var(--violet); color:#fff; border:3px solid var(--ink); border-radius:22px;
    padding:3.2rem 3rem; text-align:center; box-shadow:var(--shadow);
  }
  .contact-box h2{font-style:italic; font-size:clamp(1.8rem,3.4vw,2.6rem);}
  .contact-links{display:flex; justify-content:center; gap:1.2rem; margin-top:2rem; flex-wrap:wrap;}
  .contact-links a{
    background:#fff; color:var(--ink); font-family:"Courier New",monospace; font-weight:700;
    padding:0.75rem 1.4rem; border-radius:10px; border:3px solid var(--ink); box-shadow:4px 4px 0 rgba(0,0,0,0.35);
    transition:transform .15s ease;
  }
  .contact-links a:hover{transform:translateY(-3px);}

  footer{
    text-align:center; padding:2.2rem; font-family:"Courier New",monospace; font-size:0.8rem; color:#555;
  }

  @media (max-width:880px){
    .hero{grid-template-columns:1fr; text-align:left;}
    .avatar-wrap{margin-top:2rem;}
    .about-grid{grid-template-columns:1fr;}
    .nav-links{
      position:fixed; top:70px; right:0; height:calc(100vh - 70px); width:70vw; max-width:320px;
      background:var(--cream); flex-direction:column; padding:2rem; border-left:3px solid var(--ink);
      transform:translateX(100%); transition:transform .3s ease;
    }
    .nav-links.open{transform:translateX(0);}
    .burger{display:flex;}
  }
</style>
</head>
