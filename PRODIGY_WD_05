<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather Now</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Space+Grotesk:wght@500;600&amp;display=swap');
        
        body {
            font-family: 'Inter', system_ui, sans-serif;
        }
        
        .title-font {
            font-family: 'Space Grotesk', sans-serif;
        }

        .weather-card {
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .weather-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4);
        }

        .temp-text {
            font-size: 6rem;
            line-height: 1;
            font-weight: 600;
        }

        .bg-gradient-day {
            background: linear-gradient(to bottom, #60a5fa, #e0f2fe);
        }
        
        .search-input {
            transition: all 0.3s ease;
        }
        
        .search-input:focus {
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.3);
        }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen">
    <div class="max-w-2xl mx-auto px-4 py-8">
        <!-- Header -->
        <div class="flex items-center justify-between mb-10">
            <div class="flex items-center gap-3">
                <i class="fa-solid fa-cloud-sun text-4xl text-sky-400"></i>
                <h1 class="title-font text-4xl font-semibold tracking-tight">Weather Now</h1>
            </div>
            <div class="text-xs text-zinc-500 flex items-center gap-2">
                <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                LIVE
            </div>
        </div>

        <!-- Controls -->
        <div class="flex flex-col md:flex-row gap-4 mb-8">
            <!-- City Search -->
            <div class="flex-1">
                <div class="relative">
                    <input 
                        type="text" 
                        id="city-input"
                        placeholder="Enter city name (e.g. London)"
                        class="search-input w-full bg-zinc-900 border border-zinc-700 focus:border-sky-500 rounded-2xl px-6 py-5 text-lg outline-none placeholder-zinc-500"
                        onkeypress="if(event.key === 'Enter') getWeatherByCity()">
                    <button onclick="getWeatherByCity()" 
                            class="absolute right-3 top-1/2 -translate-y-1/2 bg-sky-600 hover:bg-sky-500 transition-colors px-8 py-3 rounded-xl font-medium">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
            </div>
            
            <!-- Current Location Button -->
            <button onclick="getCurrentLocation()"
                    class="flex items-center justify-center gap-3 bg-white text-zinc-900 hover:bg-zinc-100 transition-colors px-8 py-5 rounded-2xl font-semibold whitespace-nowrap">
                <i class="fa-solid fa-location-crosshairs"></i>
                <span>Use My Location</span>
            </button>
        </div>

        <!-- Loading State -->
        <div id="loading" class="hidden flex flex-col items-center justify-center py-20 text-zinc-400">
            <div class="animate-spin rounded-full h-12 w-12 border-t-4 border-b-4 border-sky-400 mb-6"></div>
            <p class="text-lg">Fetching weather data...</p>
        </div>

        <!-- Error Message -->
        <div id="error" class="hidden bg-red-950 border border-red-800 text-red-400 px-6 py-4 rounded-3xl text-center">
            <i class="fa-solid fa-circle-exclamation mr-2"></i>
            <span id="error-text"></span>
        </div>

        <!-- Weather Display -->
        <div id="weather-display" class="hidden">
            <!-- Main Card -->
            <div id="main-card" class="weather-card rounded-3xl p-10 text-white mb-6">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="flex items-center gap-3">
                            <div id="city-name" class="text-3xl font-semibold"></div>
                            <div id="country" class="text-sky-200 text-lg mt-1"></div>
                        </div>
                        <div id="date" class="text-sky-200 mt-1"></div>
                    </div>
                    
                    <div class="text-right">
                        <img id="weather-icon" src="" alt="weather" class="w-24 h-24 -mt-4">
                        <div id="weather-desc" class="capitalize text-xl font-medium mt-1"></div>
                    </div>
                </div>
                
                <div class="flex items-end gap-4 mt-8">
                    <div id="temperature" class="temp-text text-white"></div>
                    <div class="text-5xl text-sky-200 mb-8">°C</div>
                </div>
                
                <div class="grid grid-cols-3 gap-6 mt-12">
                    <div class="text-center">
                        <div class="text-sky-200 text-sm mb-1">FEELS LIKE</div>
                        <div id="feels-like" class="text-2xl font-semibold"></div>
                    </div>
                    <div class="text-center">
                        <div class="text-sky-200 text-sm mb-1">HUMIDITY</div>
                        <div id="humidity" class="text-2xl font-semibold"></div>
                    </div>
                    <div class="text-center">
                        <div class="text-sky-200 text-sm mb-1">WIND</div>
                        <div id="wind" class="text-2xl font-semibold"></div>
                    </div>
                </div>
            </div>
            
            <!-- Additional Details -->
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-zinc-900 rounded-3xl p-6 border border-zinc-800">
                    <div class="flex items-center gap-4">
                        <div class="bg-amber-400 text-zinc-900 w-10 h-10 rounded-2xl flex items-center justify-center">
                            <i class="fa-solid fa-eye"></i>
                        </div>
                        <div>
                            <div class="text-zinc-400 text-sm">VISIBILITY</div>
                            <div id="visibility" class="text-3xl font-semibold mt-1"></div>
                        </div>
                    </div>
                </div>
                
                <div class="bg-zinc-900 rounded-3xl p-6 border border-zinc-800">
                    <div class="flex items-center gap-4">
                        <div class="bg-sky-400 text-white w-10 h-10 rounded-2xl flex items-center justify-center">
                            <i class="fa-solid fa-droplet"></i>
                        </div>
                        <div>
                            <div class="text-zinc-400 text-sm">PRESSURE</div>
                            <div id="pressure" class="text-3xl font-semibold mt-1"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="text-center text-zinc-500 text-xs mt-12">
            Powered by OpenWeatherMap • Data updates in real-time
        </div>
    </div>

    <script>
        // === CONFIGURATION ===
        // Get your free API key at: https://openweathermap.org/api
        const API_KEY = "YOUR_API_KEY_HERE"; // ← Replace with your actual key
        
        // === DOM ELEMENTS ===
        const loadingEl = document.getElementById('loading');
        const errorEl = document.getElementById('error');
        const errorText = document.getElementById('error-text');
        const weatherDisplay = document.getElementById('weather-display');
        
        // === HELPER FUNCTIONS ===
        function showLoading() {
            loadingEl.classList.remove('hidden');
            weatherDisplay.classList.add('hidden');
            errorEl.classList.add('hidden');
        }
        
        function hideLoading() {
            loadingEl.classList.add('hidden');
        }
        
        function showError(message) {
            hideLoading();
            weatherDisplay.classList.add('hidden');
            errorText.textContent = message;
            errorEl.classList.remove('hidden');
        }
        
        function formatDate() {
            const now = new Date();
            const options = { weekday: 'long', month: 'long', day: 'numeric' };
            return now.toLocaleDateString('en-US', options);
        }
        
        function updateUI(data) {
            // Main info
            document.getElementById('city-name').textContent = data.name;
            document.getElementById('country').textContent = data.sys.country;
            document.getElementById('date').textContent = formatDate();
            
            // Temperature
            const temp = Math.round(data.main.temp);
            document.getElementById('temperature').textContent = temp;
            
            // Description + Icon
            const iconCode = data.weather[0].icon;
            document.getElementById('weather-icon').src = `https://openweathermap.org/img/wn/${iconCode}@4x.png`;
            document.getElementById('weather-desc').textContent = data.weather[0].description;
            
            // Additional fields
            document.getElementById('feels-like').textContent = Math.round(data.main.feels_like) + "°C";
            document.getElementById('humidity').textContent = data.main.humidity + "%";
            document.getElementById('wind').textContent = data.wind.speed + " m/s";
            document.getElementById('visibility').textContent = (data.visibility / 1000).toFixed(1) + " km";
            document.getElementById('pressure').textContent = data.main.pressure + " hPa";
            
            // Show the card
            hideLoading();
            weatherDisplay.classList.remove('hidden');
        }
        
        // === API CALLS ===
        async function fetchWeather(url) {
            try {
                const response = await fetch(url);
                
                if (!response.ok) {
                    if (response.status === 404) {
                        throw new Error("City not found. Please check the spelling.");
                    } else if (response.status === 401) {
                        throw new Error("Invalid API key. Please update it in the code.");
                    }
                    throw new Error("Failed to fetch weather data.");
                }
                
                const data = await response.json();
                updateUI(data);
            } catch (error) {
                console.error(error);
                showError(error.message || "Something went wrong. Please try again.");
            }
        }
        
        function getWeatherByCity() {
            const cityInput = document.getElementById('city-input');
            const city = cityInput.value.trim();
            
            if (!city) {
                showError("Please enter a city name");
                return;
            }
            
            if (API_KEY === "YOUR_API_KEY_HERE") {
                showError("Please replace 'YOUR_API_KEY_HERE' with your OpenWeatherMap API key.");
                return;
            }
            
            showLoading();
            
            const url = `https://api.openweathermap.org/data/2.5/weather?q=${encodeURIComponent(city)}&appid=${API_KEY}&units=metric`;
            fetchWeather(url);
        }
        
        function getWeatherByCoords(lat, lon) {
            if (API_KEY === "YOUR_API_KEY_HERE") {
                showError("Please replace 'YOUR_API_KEY_HERE' with your OpenWeatherMap API key.");
                return;
            }
            
            showLoading();
            
            const url = `https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lon}&appid=${API_KEY}&units=metric`;
            fetchWeather(url);
        }
        
        // === GEOLOCATION ===
        function getCurrentLocation() {
            if (!navigator.geolocation) {
                showError("Geolocation is not supported by your browser.");
                return;
            }
            
            showLoading();
            
            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const { latitude, longitude } = position.coords;
                    getWeatherByCoords(latitude, longitude);
                },
                (error) => {
                    hideLoading();
                    let message = "Unable to retrieve your location.";
                    
                    switch(error.code) {
                        case error.PERMISSION_DENIED:
                            message = "Location access denied. Please allow location access or search manually.";
                            break;
                        case error.POSITION_UNAVAILABLE:
                            message = "Location information is unavailable.";
                            break;
                        case error.TIMEOUT:
                            message = "Location request timed out.";
                            break;
                    }
                    showError(message);
                }
            );
        }
        
        // === INITIAL LOAD ===
        window.onload = function() {
            // Optional: Load a default city on startup
            // setTimeout(() => {
            //     document.getElementById('city-input').value = "New York";
            //     getWeatherByCity();
            // }, 800);
            
            console.log('%cWeather App ready! Get your API key from openweathermap.org', 'color: #60a5fa; font-size: 13px');
        };
    </script>
</body>
</html>
